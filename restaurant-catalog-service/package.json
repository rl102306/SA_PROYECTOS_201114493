{
  "name": "restaurant-catalog-service",
  "version": "1.0.0",
  "description": "Restaurant Catalog Service para Delivereats - Catálogo de productos con validación gRPC",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node src/server.ts",
     "build": "tsc && npm run copy:proto",
    "copy:proto": "mkdir -p dist/infrastructure/grpc && cp -r src/infrastructure/grpc/proto dist/infrastructure/grpc/",
    "start": "node dist/server.js"
  },
  "keywords": ["catalog", "products", "grpc", "microservices"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.10",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}

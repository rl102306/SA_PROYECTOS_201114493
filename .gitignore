# ============================================
# DELIVEREATS - .gitignore
# ============================================

# ============================================
# VARIABLES DE ENTORNO Y SECRETOS
# ============================================
.env
.env.local
.env.*.local
.env.production
.env.development
*.pem
*.key
*.p12
secrets/
credentials.json

# ============================================
# NODE.JS
# ============================================
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Build outputs
dist/
build/
out/
*.tsbuildinfo

# Cache
.npm
.eslintcache
.node_repl_history
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ============================================
# TYPESCRIPT
# ============================================
*.js.map
*.d.ts.map
tsconfig.tsbuildinfo

# ============================================
# ANGULAR
# ============================================
# Angular cache
.angular/
.angular/cache/

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# Angular specific
/e2e/*.js
/e2e/*.map

# ============================================
# DOCKER
# ============================================
# No ignorar Dockerfile ni docker-compose.yml
# pero sí los volúmenes locales
docker-compose.override.yml
.docker/

# ============================================
# LOGS
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*
log.txt

# ============================================
# BASES DE DATOS
# ============================================
# PostgreSQL
*.sql.gz
*.dump
*.backup

# SQLite
*.sqlite
*.sqlite3
*.db

# Archivos de datos locales
data/
db-data/
postgres-data/

# ============================================
# SISTEMAS OPERATIVOS
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


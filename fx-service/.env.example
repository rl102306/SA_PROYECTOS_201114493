# FX-Service — Variables de entorno de ejemplo
# Servicio de tipos de cambio USD/GTQ con caché Redis

# Puerto gRPC en el que escucha el servicio
GRPC_PORT=50056

# Entorno de ejecución
NODE_ENV=development

# Conexión a Redis (caché de tipos de cambio con TTL de 24 horas)
# En desarrollo local: Redis corre en docker-compose.dev.yml
REDIS_HOST=localhost
REDIS_PORT=6379

# URL base de la API pública de tipos de cambio (gratuita, sin API key)
# Documentación: https://www.exchangerate-api.com/docs/free
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest

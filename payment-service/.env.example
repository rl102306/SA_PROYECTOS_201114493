# Payment-Service — Variables de entorno de ejemplo
# Servicio de procesamiento de pagos (CREDIT_CARD, DEBIT_CARD, DIGITAL_WALLET)

# Puerto gRPC en el que escucha el servicio
GRPC_PORT=50057

# Entorno de ejecución
NODE_ENV=development

# Conexión a la base de datos PostgreSQL exclusiva del payment-service
# En desarrollo local: corre en docker-compose.dev.yml en el puerto 5436
DB_HOST=localhost
DB_PORT=5436
DB_NAME=payment_db
DB_USER=payment_user
DB_PASSWORD=payment_password

# URL del FX-Service para obtener tipos de cambio USD/GTQ
FX_SERVICE_URL=localhost:50056

# URL del Order-Service para actualizar el estado del pedido a PAID
ORDER_SERVICE_URL=localhost:50053

# URL del Notification-Service para enviar email de confirmación de pago
NOTIFICATION_SERVICE_URL=localhost:50055

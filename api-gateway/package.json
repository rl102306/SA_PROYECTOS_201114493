{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "API Gateway para Delivereats - Gateway REST con comunicación gRPC",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node src/server.ts",
     "build": "tsc && npm run copy:proto",
    "copy:proto": "mkdir -p dist/grpc && cp -r src/grpc/proto dist/grpc/",
    "start": "node dist/server.js"
  },
  "keywords": ["gateway", "rest", "grpc"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.10",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}

# ============================================
# DELIVEREATS — Variables de entorno de ejemplo
# Copia este archivo como .env y completa los valores reales
# NUNCA subas el .env real a GitHub
# ============================================

# ============================================
# AUTH-SERVICE (Puerto gRPC: 50052, DB: 5432)
# ============================================
AUTH_GRPC_PORT=50052
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_password
JWT_SECRET=tu-clave-super-secreta-jwt-cambiar-en-produccion-DeliverEats2026

# ============================================
# CATALOG-SERVICE (Puerto gRPC: 50051, DB: 5433)
# ============================================
CATALOG_GRPC_PORT=50051
CATALOG_DB_HOST=localhost
CATALOG_DB_PORT=5433
CATALOG_DB_NAME=catalog_db
CATALOG_DB_USER=catalog_user
CATALOG_DB_PASSWORD=catalog_password

# ============================================
# ORDER-SERVICE (Puerto gRPC: 50053, DB: 5434)
# ============================================
ORDER_GRPC_PORT=50053
ORDER_DB_HOST=localhost
ORDER_DB_PORT=5434
ORDER_DB_NAME=order_db
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=order_password

# ============================================
# DELIVERY-SERVICE (Puerto gRPC: 50054, DB: 5435)
# ============================================
DELIVERY_GRPC_PORT=50054
DELIVERY_DB_HOST=localhost
DELIVERY_DB_PORT=5435
DELIVERY_DB_NAME=delivery_db
DELIVERY_DB_USER=delivery_user
DELIVERY_DB_PASSWORD=delivery_password

# ============================================
# NOTIFICATION-SERVICE (Puerto gRPC: 50055)
# ============================================
NOTIFICATION_GRPC_PORT=50055
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password-de-16-caracteres
# Pasos para obtener App Password de Gmail:
# 1. Activar verificación en 2 pasos en tu cuenta Google
# 2. Ir a Seguridad > Contraseñas de aplicación
# 3. Generar una para "Correo" y pegar aquí

# ============================================
# FX-SERVICE (Puerto gRPC: 50056, Redis)
# ============================================
FX_GRPC_PORT=50056
REDIS_HOST=localhost
REDIS_PORT=6379
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest
# La API de tipos de cambio es gratuita, no requiere clave
# TTL del caché Redis: 24 horas (86400 segundos)

# ============================================
# PAYMENT-SERVICE (Puerto gRPC: 50057, DB: 5436)
# ============================================
PAYMENT_GRPC_PORT=50057
PAYMENT_DB_HOST=localhost
PAYMENT_DB_PORT=5436
PAYMENT_DB_NAME=payment_db
PAYMENT_DB_USER=payment_user
PAYMENT_DB_PASSWORD=payment_password
FX_SERVICE_URL=localhost:50056
ORDER_SERVICE_URL=localhost:50053
NOTIFICATION_SERVICE_URL=localhost:50055

# ============================================
# API-GATEWAY (Puerto HTTP: 3000)
# ============================================
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:4200
AUTH_SERVICE_URL=localhost:50052
CATALOG_SERVICE_URL=localhost:50051
ORDER_SERVICE_URL=localhost:50053
DELIVERY_SERVICE_URL=localhost:50054
NOTIFICATION_SERVICE_URL=localhost:50055
FX_SERVICE_URL=localhost:50056
PAYMENT_SERVICE_URL=localhost:50057
# JWT_SECRET debe coincidir exactamente con el valor usado en AUTH-SERVICE
JWT_SECRET=tu-clave-super-secreta-jwt-cambiar-en-produccion-DeliverEats2026

# ============================================
# FRONTEND (Puerto Angular: 4200)
# ============================================
# La URL del API Gateway usada por el frontend Angular
# En angular.json o environment.ts se configura:
# apiUrl: 'http://localhost:3000'
